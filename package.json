{
  "name": "forart-main",
  "private": true,
  "version": "0.1.33",
  "type": "module",
  "main": "electron/main/electron-main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --strictPort\" \"wait-on http://127.0.0.1:6981 && electron .\"",
    "dev:web": "vite --host 127.0.0.1 --strictPort",
    "electron": "electron .",
    "build": "tsc -b && vite build",
    "rebuild:native": "electron-builder install-app-deps",
    "package:dir": "npm run build && electron-builder --win --dir",
    "test:e2e": "playwright test",
    "test:e2e:canvas": "playwright test tests/electron",
    "test:e2e:canvas:update": "playwright test tests/electron --update-snapshots",
    "validate:schemas": "node scripts/validate-zod-schemas.mjs",
    "validate:i18n": "node scripts/validate-i18n.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "build": {
    "appId": "com.forart.app",
    "productName": "Forart",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "build/icon.ico",
      "!server/node_modules/**/*",
      "!server/.forart-data/**/*",
      "!server/data/**/*",
      "package.json",
      "VERSION"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "dir"
      ]
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@iconify-react/pajamas": "^1.0.2",
    "@iconify-react/ri": "^1.0.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.90.11",
    "@tanstack/react-virtual": "^3.14.5",
    "@xyflow/react": "12.11.2",
    "adm-zip": "^0.5.18",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "i18next": "^26.3.1",
    "lucide-react": "^0.468.0",
    "p-limit": "^7.3.0",
    "radix-ui": "^1.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zundo": "^2.3.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "wait-on": "^9.0.10"
  }
}
