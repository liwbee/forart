{
  "name": "forart-main",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main/electron-main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --strictPort\" \"wait-on http://127.0.0.1:6981 && electron .\"",
    "dev:web": "vite --host 127.0.0.1 --strictPort",
    "electron": "electron .",
    "build": "tsc -b && vite build",
    "package:dir": "npm run build && electron-builder --win --dir",
    "validate:i18n": "node scripts/validate-i18n.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "build": {
    "appId": "com.forart.app",
    "productName": "Forart",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "!server/node_modules/**/*",
      "!server/.forart-data/**/*",
      "!server/data/**/*",
      "package.json",
      "VERSION"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "dir"
      ]
    }
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.11",
    "adm-zip": "^0.5.18",
    "i18next": "^26.3.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "zundo": "^2.3.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "wait-on": "^9.0.10"
  }
}
